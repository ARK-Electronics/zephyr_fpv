 *
 * Clock tree (480 MHz SYSCLK), USART3 debug console,
 * RGB status LEDs, and the 3V3_SENSORS rail enable.
 *
 */

/dts-v1/;
#include <st/h7/stm32h743Xi.dtsi>
#include "ark_fpv-pinctrl.dtsi"

/ {
	model = "ARK Electronics ARK FPV";
	compatible = "ark,ark-fpv";

	chosen {
		zephyr,console = &usart3;
		zephyr,shell-uart = &usart3;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,dtcm = &dtcm;
	};

	leds: leds {
		compatible = "gpio-leds";

		/*
		 * Schematic sheet 6: nLED_RED / nLED_GREEN / nLED_BLUE are
		 * driven through the FETs on PE3/PE4/PE5. Active-low, and the
		 * board uses open-drain drive on these pins so the LED side
		 * can be 5 V tolerant — model that in DT with GPIO_OPEN_DRAIN.
		 */
		red_led: led_red {
			gpios = <&gpioe 3 (GPIO_ACTIVE_LOW | GPIO_OPEN_DRAIN)>;
			label = "LED_RED";
		};

		green_led: led_green {
			gpios = <&gpioe 4 (GPIO_ACTIVE_LOW | GPIO_OPEN_DRAIN)>;
			label = "LED_GREEN";
		};

		blue_led: led_blue {
			gpios = <&gpioe 5 (GPIO_ACTIVE_LOW | GPIO_OPEN_DRAIN)>;
			label = "LED_BLUE";
		};
	};

	aliases {
		/*
		 * led0 → blue. PX4 lights blue at boot, so we keep the same
		 * convention here for the toy app's "alive" indicator.
		 */
		led0 = &blue_led;
		led-red = &red_led;
		led-green = &green_led;
		led-blue = &blue_led;

		/*
		 * UART role aliases — these are the betaflight intent for each
		 * connector. Customer firmware can address ports by role so it
		 * doesn't depend on the specific USART/UART instance number.
		 */
		gps0 = &usart1;          /* J6 GPS1 connector */
		dji0 = &usart2;          /* J7 DJI Air Unit RX */
		esc-telem = &uart4;      /* J3 PWM ESC telemetry RX */
		vtx0 = &uart5;           /* J7 DJI / VTX DisplayPort */
		rc0 = &usart6;           /* J9 RC input */
		telem0 = &uart7;         /* J4 TELEM 1 with flow control */

		/*
		 * Motor PWM aliases — M1..M8 follow the FMU connector
		 * silkscreen on the board (sheet 6), NOT the timer channel
		 * numbers. This matches betaflight's user-facing numbering.
		 */
		motor1 = &motor_m1;
		motor2 = &motor_m2;
		motor3 = &motor_m3;
		motor4 = &motor_m4;
		motor5 = &motor_m5;
		motor6 = &motor_m6;
		motor7 = &motor_m7;
		motor8 = &motor_m8;
	};

	motors {
		/*
		 * Eight 50 Hz servo-PWM outputs on the J3/J5 motor connectors.
		 * Mapping (schematic sheet 6):
		 *   M1 = PI0  TIM5_CH4
		 *   M2 = PH11 TIM5_CH2
		 *   M3 = PH12 TIM5_CH3
		 *   M4 = PH10 TIM5_CH1
		 *   M5 = PI5  TIM8_CH1
		 *   M6 = PI6  TIM8_CH2
		 *   M7 = PI7  TIM8_CH3
		 *   M8 = PI2  TIM8_CH4
		 *
		 * `pwm-leds` is the standard container compatible — Zephyr
		 * has no `pwm-motors` binding, and the semantics (one
		 * pwm_dt_spec per child) are identical.
		 */
		compatible = "pwm-leds";

		motor_m1: motor_m1 {
			pwms = <&pwm5 4 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
		};
		motor_m2: motor_m2 {
			pwms = <&pwm5 2 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
		};
		motor_m3: motor_m3 {
			pwms = <&pwm5 3 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
		};
		motor_m4: motor_m4 {
			pwms = <&pwm5 1 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
		};
		motor_m5: motor_m5 {
			pwms = <&pwm8 1 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
		};
		motor_m6: motor_m6 {
			pwms = <&pwm8 2 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
		};
		motor_m7: motor_m7 {
			pwms = <&pwm8 3 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
		};
		motor_m8: motor_m8 {
			pwms = <&pwm8 4 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
		};
	};
};

/*
 * --- Clock tree ----------------------------------------------------------
 *
 * HSE = 16 MHz crystal (Y2, schematic sheet 5).
 * Target: SYSCLK 480 MHz, the H743's chip max — matches betaflight.
 * (PX4 deliberately runs this board at 320 MHz to limit heat dissipation;
 *  we accept the thermal trade-off to match betaflight's behaviour. If
 *  thermals become a field issue, the fallback is mul-n=160 → SYSCLK
 *  320 MHz with the rest of the tree unchanged.)
 *
 *   HSE 16 MHz / div-m=4 → PLL1 input 4 MHz
 *   * mul-n=240         → PLL1 VCO 960 MHz
 *   / div-p=2           → SYSCLK 480 MHz
 *   / div-q=8           → 120 MHz (kernel clock for SPI/SDMMC)
 *   / div-r=2           → TRACECK 480 MHz
 *
 * AHB/APB dividers (mirror nucleo_h743zi @ 480 MHz):
 *   d1cpre=1, hpre=2, d1ppre=2, d2ppre1=2, d2ppre2=2, d3ppre=2.
 */
&clk_hse {
	clock-frequency = <DT_FREQ_M(16)>;
	status = "okay";
};

&pll {
	div-m = <4>;
	mul-n = <240>;
	div-p = <2>;
	div-q = <8>;
	div-r = <2>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(480)>;
	d1cpre = <1>;
	hpre = <2>;
	d1ppre = <2>;
	d2ppre1 = <2>;
	d2ppre2 = <2>;
	d3ppre = <2>;
};

&pwr {
	/*
	 * 3V3_FMU comes from the on-board buck into VDD/VCAP — the chip's internal
	 * LDO derives the core voltage. VOS0 is selected automatically for SYSCLK ≥ 400 MHz.
	 */
	power-supply = "ldo";
};

/*
 * --- UARTs --------------------------------------------------------------
 *
 * Pin assignments per ARK_FPV.PDF (sheet 5/6) and the betaflight target:
 *
 *   usart1  TX PB6  RX PB7              GPS                 — full duplex
 *   usart2          RX PA3              DJI HD link         — RX-only
 *   usart3  TX PD8  RX PD9              debug / MSP console — full duplex (chosen)
 *   uart4           RX PH14             ESC telemetry       — RX-only
 *   uart5   TX PC12 RX PD2              VTX / DisplayPort   — full duplex
 *   usart6  TX PC6  RX PC7              RC input            — full duplex
 *   uart7   TX PE8  RX PF6  RTS PF8 CTS PE10  telemetry     — full duplex + flow control
 *
 * USART2 and UART4 only get RX pinmuxes — these connectors expose RX-only
 * signals on the board (DJI HD link is one-way; betaflight uses UART4
 * purely as an ESC telemetry sink). The corresponding TX pads are wired
 * up elsewhere on the SoC (PD5, PH13) but the board doesn't expose them.
 *
 * UART7 flow-control pins are pinmuxed so the hardware is ready, but
 * `hw-flow-control` is not enabled by default — turn it on per-app if
 * the connected peripheral requires it.
 */
&usart1 {
	pinctrl-0 = <&usart1_tx_pb6 &usart1_rx_pb7>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&usart2 {
	pinctrl-0 = <&usart2_rx_pa3>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&usart3 {
	pinctrl-0 = <&usart3_tx_pd8 &usart3_rx_pd9>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&uart4 {
	pinctrl-0 = <&uart4_rx_ph14>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&uart5 {
	pinctrl-0 = <&uart5_tx_pc12 &uart5_rx_pd2>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&usart6 {
	pinctrl-0 = <&usart6_tx_pc6 &usart6_rx_pc7>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&uart7 {
	pinctrl-0 = <&uart7_tx_pe8 &uart7_rx_pf6
		     &uart7_rts_pf8 &uart7_cts_pe10>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

/*
 * --- Motor PWM (TIM5 → M1-M4, TIM8 → M5-M8) -----------------------------
 *
 * Timer kernel clock on the H743 with d2ppre1=d2ppre2=2 is 2 × APB =
 * 240 MHz. st,prescaler = 239 yields a 1 MHz counter (1 µs / tick) for
 * both timers — fine resolution for 50 Hz servo PWM (1000–2000 µs pulse
 * width) and leaves headroom for tighter periods later.
 *
 * Neither TIM5 nor TIM8 is wired to the Zephyr kernel timer (default is
 * the Cortex-M SysTick). The optional heater
 * PWM on TIM2_CH3 (PB10) and the M9 output on TIM4_CH1 (PD12) are out
 * of scope and left disabled.
 *
 * Safety: do not connect ESCs while running the sweep app — the
 * duty cycle will move continuously across the throttle range.
 */
&timers5 {
	st,prescaler = <239>;
	status = "okay";

	pwm5: pwm {
		status = "okay";
		pinctrl-0 = <&tim5_ch1_ph10 &tim5_ch2_ph11
			     &tim5_ch3_ph12 &tim5_ch4_pi0>;
		pinctrl-names = "default";
	};
};

&timers8 {
	st,prescaler = <239>;
	status = "okay";

	pwm8: pwm {
		status = "okay";
		pinctrl-0 = <&tim8_ch1_pi5 &tim8_ch2_pi6
			     &tim8_ch3_pi7 &tim8_ch4_pi2>;
		pinctrl-names = "default";
	};
};

/*
 * --- 3V3_SENSORS rail enable ------------------------------------------
 *
 * The NCV8177AMX330TCG sensor LDO (U4, sheet 2) is gated by
 * VDD_3V3_SENSORS1_EN on PI11. Until this pin is driven high every
 * peripheral on the 3V3_SENSORS rail (BMP390 VDD, IIS2MDC VDD_IO, the
 * IIM-42653, the external SPI6 connector) is dead. Drive it on at kernel
 * start via a gpio-hog so you can talk to sensors without
 * having to remember to flip it.
 */
&gpioi {
	sensor_3v3_en {
		gpio-hog;
		gpios = <11 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "VDD_3V3_SENSORS1_EN";
	};
};
